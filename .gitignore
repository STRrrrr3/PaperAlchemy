# 忽略 Python 的编译垃圾
__pycache__/
*.py[cod]

# 忽略虚拟环境
venv/
.venv/
env/

# 忽略 IDE 的配置文件
.vscode/
.idea/

# 忽略敏感信息
.env

# 忽略论文原始与中间数据（体积大、不可复现）
data/input/
data/output/

# 忽略采集与提取生成物（可通过脚本重建）
data/collectors(useless)/raw/
data/collectors(useless)/output/
data/collectors(useless)/modules/

# 保留采集脚本与文档（用于开源复现）
!data/collectors(useless)/
!data/collectors(useless)/*.py
!data/collectors(useless)/README.md

# 保留可复现锁文件
!data/collectors(useless)/locks/
!data/collectors(useless)/locks/*.json
!data/collectors(useless)/locks/.gitkeep

