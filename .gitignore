# 忽略 Python 的编译垃圾
__pycache__/
*.py[cod]

# 忽略工具缓存与临时目录
.ruff_cache/
.pytest_cache/
.uv-cache/
.uv-cache-local/
.uv-python/
.tmp.driveupload/
tests/_tmp/

# 忽略虚拟环境
venv/
.venv/
env/

# 忽略 IDE 的配置文件
.vscode/
.idea/

# 忽略敏感信息
.env
project-*.json
AGENTS.md
PaperAlchemy_System_Architecture_for_ChatGPT.md
TASK_MEMORY.md
test_env.py
tests/
data/
CLAUDE.md
settings.local.json

# 忽略论文原始与中间数据（体积大、不可复现）
data/input/
data/output/

# Local Google / Vertex service-account credentials
service-account*.json
google-service-account*.json
vertex-service-account*.json
